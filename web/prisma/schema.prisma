// Local dev: DATABASE_URL in .env.local (Cloud SQL Proxy → 127.0.0.1:5433)
// Production: DATABASE_URL or PGHOST/PGPASSWORD from env (e.g. /cloudsql/...)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TableColumnOrder {
  id          String   @id @default(cuid())
  tableName   String   @unique @map("table_name")
  columnOrder String   @map("column_order") // JSON array of column names
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("tbl_table_column_order")
}

model User {
  userid    BigInt   @id @default(autoincrement())
  email     String   @unique @db.VarChar(255)
  password  String   @db.Text
  firstname String?  @db.VarChar(100)
  surname   String?  @db.VarChar(100)
  phone     String?  @db.VarChar(50)
  userType  String?  @default("Admin") @db.VarChar(50) @map("user_type")   // 'Super Admin' | 'Admin' | 'Client'
  customer  String?  @db.VarChar(255) @map("customer")                     // for Client: assigned customer from tbl_vworkjobs
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tbl_users")
}

model Log {
  logid       BigInt   @id @default(autoincrement())
  logdatetime DateTime @default(now()) @map("logdatetime")
  logtype     String   @db.VarChar(50)
  logcat1     String?  @db.VarChar(100)
  logcat2     String?  @db.VarChar(100)
  logdetails  String?  @db.Text

  @@map("tbl_logs")
}

model TblGpsmapping {
  id      Int    @id @default(autoincrement())
  type    String @db.VarChar(50)
  vwname  String @db.VarChar(100)
  gpsname String @db.VarChar(100)

  @@map("tbl_gpsmappings")
}

model Setting {
  id           Int     @id @default(autoincrement())
  type         String  @db.VarChar(50)
  settingname  String  @map("settingname")
  settingvalue String? @db.Text

  @@unique([type, settingname])
  @@map("tbl_settings")
}
